# LOGOS Centralized Configuration
# Copy this file to .env and customize as needed.

# --- Required Secrets ---
# OpenAI API Key for LLM operations (Hermes)
OPENAI_API_KEY=

# --- Service Configuration ---

# Hermes (Language & Embedding Service)
HERMES_HOST=0.0.0.0
HERMES_PORT=17000
# External URL for other services to reach Hermes (e.g. from Apollo)
HERMES_URL=http://localhost:17000

# Apollo (Orchestration & API)
APOLLO_HOST=0.0.0.0
APOLLO_PORT=27000
# External URL for the webapp to reach Apollo
APOLLO_API_URL=http://localhost:27000

# Sophia (Cognitive Core)
SOPHIA_HOST=0.0.0.0
SOPHIA_PORT=47000
# Bearer token the webapp / Hermes / Apollo use to authenticate to Sophia.
# Sophia refuses requests without it (its HCG + persona routes are token-gated).
SOPHIA_API_TOKEN=sophia_dev

# --- Infrastructure ---

# Neo4j (Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jtest
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Milvus (Vector Database)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091

# SHACL Validation
SHACL_API_PORT=8081

# --- Webapp Configuration ---
# These are picked up by Vite during build/dev
# Maps central variables to Vite-specific names
VITE_HCG_API_URL=${APOLLO_API_URL}
VITE_HCG_WS_URL=ws://localhost:${APOLLO_PORT}/ws/diagnostics
VITE_SOPHIA_API_URL=http://localhost:${SOPHIA_PORT}
# Token for the webapp's HCG + persona calls to Sophia. Must match
# SOPHIA_API_TOKEN above. run_apollo.sh also writes these into
# webapp/.env.local on launch, so this is mainly for reference / custom setups.
VITE_SOPHIA_API_KEY=${SOPHIA_API_TOKEN}
VITE_HERMES_API_URL=${HERMES_URL}

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=apollo
OTEL_CONSOLE_EXPORT=false
