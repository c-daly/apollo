# HCG API
VITE_HCG_API_URL=http://localhost:27000
VITE_HCG_WS_URL=ws://localhost:8765
VITE_HCG_TIMEOUT=30000

# Sophia API
VITE_SOPHIA_API_URL=http://localhost:47000
# Must match SOPHIA_API_TOKEN in the root .env -- Sophia's HCG + persona routes
# are token-gated, so an empty key returns 403s and a blank dashboard. Launching
# via scripts/run_apollo.sh writes this into webapp/.env.local for you.
VITE_SOPHIA_API_KEY=sophia_dev
VITE_SOPHIA_TIMEOUT=30000

# Hermes API
VITE_HERMES_API_URL=http://localhost:17000
VITE_HERMES_API_KEY=
VITE_HERMES_TIMEOUT=30000
VITE_HERMES_LLM_PROVIDER=
VITE_HERMES_LLM_MODEL=
VITE_HERMES_LLM_TEMPERATURE=
VITE_HERMES_LLM_MAX_TOKENS=
VITE_HERMES_SYSTEM_PROMPT=

# Features
VITE_ENABLE_CHAT=true
VITE_ENABLE_DIAGNOSTICS=true

# App metadata
VITE_APP_VERSION=dev

# Mock Data Mode
# Set to 'true' to use mock CWMState fixtures instead of live data
# Useful for development and testing without backend services
VITE_MOCK_DATA_MODE=false
